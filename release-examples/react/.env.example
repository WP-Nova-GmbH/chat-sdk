# --- Server-side only (used by the Vite token-endpoint proxy, never shipped to the browser) ---
# Nova API origin that serves POST /embed/session.
NOVA_TOKEN_BASE_URL=http://localhost:8400
# Surface integration secret. Keep this on the server. Never expose it to the browser.
NOVA_INTEGRATION_SECRET=replace_me
# The "authenticated user" email the proxy asserts to Nova. In a real backend this
# comes from the user's session, not from config.
NOVA_TEST_EMAIL=tester@example.com

# --- Browser-safe (VITE_ vars are inlined into client code) ---
# Public, non-secret surface handle from Nova admin.
VITE_NOVA_PUBLIC_SURFACE_ID=surf_replace_me
# Nova iframe host. Defaults to https://chat.wp-nova.ai when omitted.
VITE_NOVA_BASE_URL=http://localhost:5173
