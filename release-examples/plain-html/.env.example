# --- Server-side only (used by the Vite token-endpoint proxy, never shipped to the browser) ---
NOVA_TOKEN_BASE_URL=http://localhost:8400
NOVA_INTEGRATION_SECRET=replace_me
NOVA_TEST_EMAIL=tester@example.com

# --- Browser-safe (injected into the static page by vite.config.ts) ---
VITE_NOVA_PUBLIC_SURFACE_ID=surf_replace_me
VITE_NOVA_BASE_URL=http://localhost:5173
