{
    "$schema": "https://turbo.build/schema.json",
    "ui": "tui",
    "globalPassThroughEnv": ["GITHUB_OUTPUT"],
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": ["dist/**", "build/**", ".docusaurus/**", "LICENSE"]
        },
        "check-types": {
            "dependsOn": ["^check-types"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "test": {
            "dependsOn": ["build"],
            "outputs": ["coverage/**"]
        }
    }
}
